{
  "name": "votrix-user-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "npm --workspace=apps/web run web",
    "build:web": "npm run build --workspace=apps/web",
    "lint:web": "npm run lint --workspace=apps/web",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "mob": "npm run native --workspace=apps/mobile",
    "ios": "npm run ios --workspace=apps/mobile",
    "android": "npm run android --workspace=apps/mobile"
  }
}
